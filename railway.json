{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixpkgsChannel": "stable-23_05"
        },
        "install": {
          "dependsOn": ["setup"],
          "nixpacksExposes": ["nodejs"]
        },
        "build": {
          "dependsOn": ["install"],
          "cmds": [
            "npm ci",
            "npm run build:mcp",
            "npm prune --omit=dev || true"
          ],
          "nixpkgsChannel": "stable-23_05"
        }
      },
      "providers": ["node"]
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "node http-server.cjs"
  }
}
